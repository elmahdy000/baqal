// Baqal — Multi-Tenant SaaS Grocery Platform
// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum UserRole {
  SUPER_ADMIN
  STORE_OWNER
  STORE_STAFF
  DELIVERY
  CUSTOMER
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ProductUnit {
  PIECE
  KG
  GRAM
  LITER
  ML
  PACK
  BOX
  CARTON
  DOZEN
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ORDER_RESERVED
  ORDER_CANCELLED
  MANUAL_ADJUSTMENT
  DAMAGED
  EXPIRED
  RETURNED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  PAY_LATER
  WALLET
  CARD_LATER
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}

enum NotificationType {
  ORDER_NEW
  ORDER_ACCEPTED
  ORDER_REJECTED
  ORDER_PREPARING
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  ORDER_CANCELLED
  LOW_STOCK
  OUT_OF_STOCK
  OFFER
  SYSTEM
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PlanTier {
  BASIC
  PLUS
  PRO
  ENTERPRISE
}

enum CustomRequestStatus {
  PENDING
  ANSWERED_AVAILABLE
  ANSWERED_UNAVAILABLE
  ANSWERED_SOON
}

enum SettlementStatus {
  PENDING
  PAID
  CANCELLED
}

enum SettlementMethod {
  CASH
  BANK_TRANSFER
  INSTAPAY
  VODAFONE_CASH
  OTHER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketAuthorRole {
  STORE
  ADMIN
}

// ---------- Auth ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  role         UserRole @default(STORE_OWNER)
  storeId      String?
  store        Store?   @relation("StoreUsers", fields: [storeId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs         AuditLog[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  assignedOrders    Order[]            @relation("DriverOrders")
  supportTickets    SupportTicket[]    @relation("UserSupportTickets")
  assignedSupportTickets   SupportTicket[]        @relation("AssignedSupportTickets")
  supportTicketMessages    SupportTicketMessage[] @relation("SupportTicketAuthoredMessages")
  cashierSales      WalkInSale[]       @relation("CashierSales")

  @@index([storeId])
  @@index([role])
}

// ---------- Store / tenant ----------

model Store {
  id             String      @id @default(cuid())
  name           String
  nameAr         String?
  slug           String      @unique
  phone          String?
  email          String?
  logoUrl        String?
  status         StoreStatus @default(ACTIVE)
  isOpen         Boolean     @default(true)
  openingHours   String?
  deliveryFee    Decimal     @default(0) @db.Decimal(10, 2)
  minOrderAmount Decimal     @default(0) @db.Decimal(10, 2)
  address        String?
  platformCommissionRate Decimal @default(5) @db.Decimal(5, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  users              User[]              @relation("StoreUsers")
  products           Product[]
  categories         Category[]
  buildings          Building[]
  qrCodes            QRCode[]
  orders             Order[]
  customers          Customer[]
  inventoryMovements InventoryMovement[]
  notifications      Notification[]
  offers             Offer[]
  customRequests     CustomRequest[]
  subscription       Subscription?
  settlements        Settlement[]
  supportTickets     SupportTicket[]     @relation("StoreSupportTickets")
  walkInSales        WalkInSale[]

  @@index([status])
  @@index([slug])
}

// ---------- Locations ----------

model Area {
  id        String     @id @default(cuid())
  name      String
  nameAr    String?
  city      String?
  createdAt DateTime   @default(now())
  buildings Building[]
}

model Building {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  areaId         String?
  area           Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  street         String?
  buildingNumber String?
  compoundName   String?
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deliveryFee    Decimal? @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  qrCodes QRCode[]
  orders  Order[]

  @@index([storeId])
  @@index([code])
}

model QRCode {
  id            String    @id @default(cuid())
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  buildingId    String
  building      Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  code          String    @unique
  url           String
  isActive      Boolean   @default(true)
  scanCount     Int       @default(0)
  lastScannedAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([storeId])
  @@index([buildingId])
}

// ---------- Catalog ----------

model Category {
  id        String    @id @default(cuid())
  name      String
  nameAr    String
  slug      String
  icon      String?
  order     Int       @default(0)
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([storeId, slug])
  @@index([storeId])
}

model Product {
  id                String      @id @default(cuid())
  name              String
  nameAr            String?
  description       String?
  categoryId        String?
  category          Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  price             Decimal     @db.Decimal(10, 2)
  discountPrice     Decimal?    @db.Decimal(10, 2)
  stockQuantity     Int         @default(0)
  unit              ProductUnit @default(PIECE)
  imageUrl          String?
  barcode           String?
  isAvailable       Boolean     @default(true)
  lowStockThreshold Int         @default(5)
  expiryDate        DateTime?
  storeId           String
  store             Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
  favorites          FavoriteProduct[]
  walkInSaleItems    WalkInSaleItem[]

  @@unique([storeId, barcode])
  @@index([storeId])
  @@index([categoryId])
  @@index([name])
  @@index([barcode])
}

// ---------- Inventory ----------

model InventoryMovement {
  id          String                @id @default(cuid())
  productId   String
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type        InventoryMovementType
  quantity    Int
  oldQuantity Int
  newQuantity Int
  reason      String?
  createdBy   String?
  createdAt   DateTime              @default(now())

  @@index([productId])
  @@index([storeId])
}

// ---------- Customer ----------

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses      Address[]
  orders         Order[]
  favorites      FavoriteProduct[]
  customRequests CustomRequest[]

  @@unique([storeId, phone])
  @@index([storeId])
}

model Address {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  buildingId    String?
  buildingName  String?
  floor         String?
  apartment     String?
  street        String?
  deliveryNotes String?
  isDefault     Boolean  @default(true)
  createdAt     DateTime @default(now())

  orders Order[]

  @@index([customerId])
}

// ---------- Orders ----------

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  storeId       String
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  buildingId    String?
  building      Building?     @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  addressId     String?
  address       Address?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  driverId      String?
  driver        User?         @relation("DriverOrders", fields: [driverId], references: [id], onDelete: SetNull)
  status        OrderStatus   @default(PENDING)
  subtotal      Decimal       @db.Decimal(10, 2)
  deliveryFee   Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  rejectReason  String?
  platformCommissionRate Decimal? @db.Decimal(5, 2)
  platformCommission     Decimal? @db.Decimal(10, 2)
  platformCommissionSettledAt DateTime?
  settlementId  String?
  settlement    Settlement?   @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items   OrderItem[]
  history OrderStatusHistory[]

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([storeId, status])
  @@index([storeId, createdAt])
  @@index([platformCommissionSettledAt])
  @@index([settlementId])
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String
  order               Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product @relation(fields: [productId], references: [id])
  productNameSnapshot String
  quantity            Int
  unitPrice           Decimal @db.Decimal(10, 2)
  totalPrice          Decimal @db.Decimal(10, 2)
  notes               String?

  @@index([orderId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdBy String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

// ---------- Notifications ----------

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([storeId])
  @@index([isRead])
}

// ---------- Audit ----------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

// ---------- Push notifications ----------

model PushSubscription {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerPhone String?
  storeId       String?
  endpoint      String   @unique
  p256dh        String
  auth          String
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([customerPhone])
  @@index([storeId])
}

// ---------- SaaS billing ----------

model Plan {
  id             String        @id @default(cuid())
  tier           PlanTier      @unique
  name           String
  nameAr         String
  priceMonthly   Decimal       @db.Decimal(10, 2)
  priceYearly    Decimal       @db.Decimal(10, 2)
  maxBuildings  Int
  maxProducts   Int
  maxStoreUsers Int
  features      Json?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id           String             @id @default(cuid())
  storeId      String             @unique
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  planId       String
  plan         Plan               @relation(fields: [planId], references: [id])
  status       SubscriptionStatus @default(TRIAL)
  billingCycle BillingCycle       @default(MONTHLY)
  startsAt     DateTime           @default(now())
  endsAt       DateTime?
  renewalDate  DateTime?
  amount       Decimal            @db.Decimal(10, 2)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([status])
}

// ---------- Offers ----------

model Offer {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
  discountPct Int?
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  isActive    Boolean   @default(true)
  productIds  String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([storeId])
  @@index([isActive])
}

// ---------- Favorites ----------

model FavoriteProduct {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
}

// ---------- Custom requests (missing products) ----------

model CustomRequest {
  id         String              @id @default(cuid())
  storeId    String
  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  text       String
  reply      String?
  status     CustomRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([storeId])
  @@index([customerId])
}

// ---------- Support tickets ----------

model SupportTicket {
  id               String                @id @default(cuid())
  storeId          String?
  store            Store?                @relation("StoreSupportTickets", fields: [storeId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?                 @relation("UserSupportTickets", fields: [userId], references: [id], onDelete: SetNull)
  assignedAdminId  String?
  assignedAdmin    User?                 @relation("AssignedSupportTickets", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  subject          String
  message          String
  status           SupportTicketStatus   @default(OPEN)
  priority         SupportTicketPriority @default(NORMAL)
  reply            String?
  replyAt          DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  messages         SupportTicketMessage[]

  @@index([storeId])
  @@index([userId])
  @@index([assignedAdminId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model SupportTicketMessage {
  id         String                  @id @default(cuid())
  ticketId   String
  ticket     SupportTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorRole SupportTicketAuthorRole
  authorId   String?
  author     User?                   @relation("SupportTicketAuthoredMessages", fields: [authorId], references: [id], onDelete: SetNull)
  body       String
  createdAt  DateTime                @default(now())

  @@index([ticketId])
  @@index([authorId])
  @@index([createdAt])
}

// ---------- Walk-in sales (POS) ----------

model WalkInSale {
  id            String        @id @default(cuid())
  storeId       String
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  saleNumber    String        @unique
  cashierId     String?
  cashier       User?         @relation("CashierSales", fields: [cashierId], references: [id], onDelete: SetNull)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH_ON_DELIVERY)
  notes         String?
  createdAt     DateTime      @default(now())

  items WalkInSaleItem[]

  @@index([storeId])
  @@index([createdAt])
}

model WalkInSaleItem {
  id                  String     @id @default(cuid())
  saleId              String
  sale                WalkInSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId           String
  product             Product    @relation(fields: [productId], references: [id])
  productNameSnapshot String
  quantity            Int
  unitPrice           Decimal    @db.Decimal(10, 2)
  totalPrice          Decimal    @db.Decimal(10, 2)

  @@index([saleId])
}

// ---------- Platform commission / settlements ----------

model Settlement {
  id          String            @id @default(cuid())
  storeId     String
  store       Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  amount      Decimal           @db.Decimal(12, 2)
  orderCount  Int
  fromDate    DateTime
  toDate      DateTime
  status      SettlementStatus  @default(PENDING)
  method      SettlementMethod?
  reference   String?
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  orders Order[]

  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}
